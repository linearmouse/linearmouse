    "Choose a mouse button trigger. Left click without modifier keys is not allowed." : {
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kies 'n muisknoppie-sneller. Linkskliek sonder wysigingsleutels word nie toegelaat nie."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اختر مشغل زر الماوس. لا يُسمح بالنقر الأيسر بدون مفاتيح تعديل."
          }
        },
        "bs" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Choose a mouse button trigger. Left click without modifier keys is not allowed."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tria un disparador de botó del ratolí. No es permet fer clic esquerre sense tecles modificadores."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vyberte spoušť tlačítka myši. Kliknutí levým tlačítkem bez modifikačních kláves není povoleno."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vælg en museknapudløser. Venstreklik uden genvejstaster er ikke tilladt."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wählen Sie eine Maustastenauslösung. Ein Linksklick ohne Modifikatortasten ist nicht erlaubt."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Επιλέξτε ένα έναυσμα κουμπιού ποντικιού. Το αριστερό κλικ χωρίς πλήκτρα τροποποίησης δεν επιτρέπεται."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige un disparador de botón del ratón. No se permite el clic izquierdo sin teclas modificadoras."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Valitse hiiren painikkeen laukaisin. Vasemmanpuoleinen napsautus ilman muokkausnäppäimiä ei ole sallittua."

    "Hold the trigger while moving to scroll, then release it to stop." : {
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hou die sneller vas terwyl jy beweeg om te blaai, en laat dit dan los om te stop."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اضغط مع الاستمرار على المشغل أثناء التحريك للتمرير، ثم حرره للتوقف."
          }
        },
        "bs" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Hold the trigger while moving to scroll, then release it to stop."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantén premut el disparador mentre et mous per desplaçar-te, després deixa'l anar per aturar-te."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Podržte spoušť při pohybu pro rolování, poté ji uvolněte pro zastavení."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",

    "Hold the button and drag to trigger gestures. Drag at least %lld pixels in one direction." : {
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hou die knoppie vas en sleep om gebare te aktiveer. Sleep ten minste %lld pixels in een rigting."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اضغط مع الاستمرار على الزر واسحب لتشغيل الإيماءات. اسحب %lld بكسل على الأقل في اتجاه واحد."
          }
        },
        "bs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Držite dugme i prevucite da biste pokrenuli geste. Prevucite najmanje %lld piksela u jednom smjeru."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantén premut el botó i arrossega per activar gestos. Arrossega almenys %lld píxels en una direcció."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Podržte tlačítko a přetáhněte pro spuštění gest. Přetáhněte alespoň %lld pixelů jedním směrem."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hold knappen nede og træk for at udløse gestus. Træk mindst %lld pixels i én retning."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Halten Sie die Schaltfläche gedrückt und ziehen Sie, um Gesten auszulösen. Ziehen Sie mindestens %lld Pixel in eine Richtung."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Κρατήστε πατημένο το κουμπί και σύρετε για να ενεργοποιήσετε χειρονομίες. Σύρετε τουλάχιστον %lld pixel προς μία κατεύθυνση."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantén pulsado el botón y arrastra para producir gestos. Arrastra al menos %lld píxeles en una dirección."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pidä painiketta painettuna ja vedä eleiden käynnistämiseksi. Vedä vähintään %lld pikseliä yhteen suuntaan."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maintenez le bouton enfoncé et faites glisser pour déclencher des gestes. Faites glisser sur au moins %lld pixels dans une direction."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "החזק את הלחצן וגרור כדי להפעיל מחוות. גרור לפחות %lld פיקסלים בכיוון אחד."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tartsa lenyomva a gombot, és húzza az érintés aktiválásához. Húzza legalább %lld képpont távolságra egy irányban."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Hold the button and drag to trigger gestures. Drag at least %lld pixels in one direction."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tieni premuto il pulsante e trascina per attivare i gesti. Trascina almeno %lld pixel in una direzione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ボタンを押したままドラッグしてジェスチャーをトリガーします。いずれかの方向に少なくとも%lldピクセルドラッグしてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "버튼을 누른 상태에서 드래그하여 제스처를 트리거합니다. 한 방향으로 최소 %lld 픽셀을 드래그하세요."
          }
        },
        "my" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "အမူအယာများကို trigger လုပ်ရန် ခလုတ်ကို ကိုင်ပြီး ဆွဲပါ။ တစ်ဖက်သို့ အနည်းဆုံး %lld pixels ဆွဲပါ။"
          }
        },
        "nb-NO" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Hold the button and drag to trigger gestures. Drag at least %lld pixels in one direction."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Houd de knop ingedrukt en sleep om gebaren te activeren. Sleep minstens %lld pixels in één richting."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przytrzymaj przycisk i przeciągnij, aby wywołać gesty. Przeciągnij co najmniej %lld pikseli w jednym kierunku."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantenha o botão pressionado e arraste para acionar gestos. Arraste pelo menos %lld pixels em uma direção."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantenha o botão pressionado e arraste para acionar gestos. Arraste pelo menos %lld pixels em uma direção."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ține apăsat butonul și trage pentru a declanșa gesturi. Trage cel puțin %lld pixeli într-o direcție."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Удерживайте кнопку и перетаскивайте, чтобы активировать жесты. Перетащите не менее %lld пикселей в одном направлении."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Podržte tlačidlo a potiahnite, aby ste spustili gestá. Potiahnite aspoň %lld pixelov jedným smerom."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Држите дугме и превуците да бисте покренули покрете. Превуците најмање %lld пиксела у једном смеру."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Håll ned knappen och dra för att aktivera gester. Dra minst %lld pixlar i en riktning."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hareketleri tetiklemek için düğmeyi basılı tutun ve sürükleyin. Tek bir yönde en az %lld piksel sürükleyin."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Утримуйте кнопку та перетягніть, щоб викликати жести. Перетягніть щонайменше на %lld пікселів в одному напрямку."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Giữ nút và kéo để kích hoạt cử chỉ. Kéo ít nhất %lld pixel theo một hướng."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "按住按钮并拖动以触发手势。沿一个方向拖动至少 %lld 像素。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "按住按鈕並拖曳以觸發手勢。朝任一方向拖曳至少 %lld 個像素。"
          }
        },
        "zh-Hant-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "按住按鈕並拖曳以觸發手勢。朝一個方向拖曳至少 %lld 個像素。"
          }
        }
      }

    "Distance must be \"auto\" or a number or a string representing value and unit" : {
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Afstand moet \"auto\" of 'n getal of 'n string wees wat waarde en eenheid voorstel"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يجب أن تكون المسافة \"auto\" أو رقمًا أو سلسلة تمثل القيمة والوحدة"
          }
        },
        "bs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Udaljenost mora biti \"auto\", broj ili tekst koji predstavljaju mjeru i jedinicu mjere"
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La distància ha de ser \"auto\" o un número o una cadena que representi el valor i la unitat"
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vzdálenost musí být „auto“ nebo číslo nebo řetězec reprezentující hodnotu a jednotku"
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Afstand skal være \"auto\" eller et tal eller en streng, der repræsenterer værdi og enhed"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Abstand muss „auto“ oder eine Zahl oder eine Zeichenfolge sein, die Wert und Einheit darstellt"
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Η απόσταση πρέπει να είναι \"auto\" ή ένας αριθμός ή μια συμβολοσειρά που αντιπροσωπεύει τιμή και μονάδα"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La distancia debe ser \"auto\", un número o una cadena representando valor y unidad"
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Etäisyyden on oltava \"auto\" tai numero tai arvoa ja yksikköä edustava merkkijono"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La distance doit être « auto » ou un nombre ou une chaîne représentant la valeur et l’unité"
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "המרחק חייב להיות \"auto\" או מספר או מחרוזת המייצגת ערך ויחידה"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A távolságnak \"auto\" vagy számnak, vagy az értéket és mértékegységet reprezentáló sztringnek kell lennie"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Distance must be \"auto\" or a number or a string representing value and unit"

    "Scroll by moving away from an anchor point, similar to Windows middle-click autoscroll." : {
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Blaai deur weg te beweeg van 'n ankerpunt, soortgelyk aan Windows-middelklik-outoblai."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "التمرير بالابتعاد عن نقطة ارتكاز، مشابه للتمرير التلقائي للنقر الأوسط في Windows."
          }
        },
        "bs" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Scroll by moving away from an anchor point, similar to Windows middle-click autoscroll."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desplaça't allunyant-te d'un punt d'ancoratge, similar al desplaçament automàtic amb el clic central de Windows."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Posouvejte se odsunutím od referenčního bodu, podobně jako automatické posouvání prostředním kliknutím ve Windows."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rul ved at bevæge dig væk fra et ankerpunkt, ligesom Windows mellemklik autoscroll."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scrollen Sie, indem Sie sich von einem Ankerpunkt wegbewegen, ähnlich wie beim automatischen Scrollen mit der mittleren Maustaste unter Windows."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Κυλίστε μετακινώντας μακριά από ένα σημείο αγκύρωσης, παρόμοιο με την αυτόματη κύλιση μεσαίου κλικ των Windows."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desplázate alejándote de un punto de anclaje, similar al desplazamiento automático del clic central de Windows."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vieritä siirtymällä poispäin ankkuripisteestä, samankaltaisesti kuin Windowsin keskinäppäimen automaattinen vieritys."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Faites défiler en vous éloignant d’un point d’ancrage, similaire au défilement automatique du clic milieu de Windows."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "גלול על ידי התרחקות מנקודת עוגן, בדומה לגלילה אוטומטית של לחיצת אמצע ב-Windows."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Görgessen el egy rögzítési ponttól távolodva, hasonlóan a Windows középső kattintásos automatikus görgetéséhez."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Scroll by moving away from an anchor point, similar to Windows middle-click autoscroll."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scorri allontanandoti da un punto di ancoraggio, simile allo scorrimento automatico con clic centrale di Windows."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アンカーポイントから離れるようにスクロールします。Windowsの中クリック自動スクロールに似ています。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "기준점에서 멀리 이동하여 스크롤합니다. Windows 중앙 클릭 자동 스크롤과 유사합니다."
          }
        },
        "my" : {
          "stringUnit" : {
            "state" : "new",

          }
        },
        "nb-NO" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Scroll by moving away from an anchor point, similar to Windows middle-click autoscroll."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scrollen door weg te bewegen van een ankerpunt, vergelijkbaar met de automatische scrollfunctie van de middenklik in Windows."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przewijaj, oddalając się od punktu kotwiczenia, podobnie jak automatyczne przewijanie środkowym przyciskiem myszy w systemie Windows."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Role afastando-se de um ponto de ancoragem, semelhante à rolagem automática com clique do meio do mouse no Windows."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Role movendo-se para longe de um ponto de ancoragem, semelhante à rolagem automática do clique do meio do Windows."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Derulează mișcându-te departe de un punct de ancorare, similar cu derularea automată cu clic din mijloc din Windows."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Прокручивайте, отводя курсор от точки привязки, аналогично автопрокрутке средней кнопкой мыши в Windows."

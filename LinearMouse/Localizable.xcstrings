    "If enabled, %@ will not modify events sent by other applications, such as Logi Options+." : {
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Indien geaktiveer, sal %@ nie gebeurtenisse wat deur ander toepassings gestuur word, soos Logi Options+, wysig nie."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إذا تم تمكين هذا الخيار، فلن يقوم %@ بتعديل الأحداث المرسلة من تطبيقات أخرى، مثل Logi Options+."
          }
        },
        "bs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ako je omogućeno, %@ neće mijenjati događaje koje šalju druge aplikacije, kao npr. Logi Options+."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si s'habilita, %@ no modificarà els esdeveniments enviats per altres aplicacions, com ara Logi Options+."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Po zapnutí nebude %@ upravovat události poslané ostatními aplikacemi jako je Logi Options+."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hvis aktiveret, vil %@ ikke ændre begivenheder sendt af andre programmer, såsom Logi Options+."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn aktiviert, verändert %@ keine Ereignisse, die von anderen Anwendungen, wie z. B. Logi Options+, gesendet werden."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Αν ενεργοποιηθεί, το %@ δε θα τροποποιήσει τα συμβάντα που αποστέλλονται από άλλες εφαρμογές, όπως το Logi Options+."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si está activado, %@ no modificará los eventos enviados por otras aplicaciones, tales como Logi Options+."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jos tämä on käytössä, %@ ei muokkaa muiden sovellusten, kuten Logi Options+:n, lähettämiä tapahtumia."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si activé, %@ ne modifiera pas les événements envoyés par d'autres applications, telles que Logi Options+."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "אם פועל, %@ לא ישנה אירועים שנשלחים מאפליקציות אחרות, כמו Logi Options+."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ha engedélyezve van, a(z) %@ nem módosítja más alkalmazások által küldött eseményeket, például a Logi Options+-t."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "If enabled, %@ will not modify events sent by other applications, such as Logi Options+."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se abilitato, %@ non modificherà gli eventi inviati da altre applicazioni, come Logi Options+."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "有効にすると、 %@ はLogi Options+などの他のアプリケーションから送信されたイベントを変更しません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "활성화되면, %@는 Logi Options+와 같은 다른 응용 프로그램에서 보낸 이벤트를 수정하지 않습니다."
          }
        },
        "my" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "အသုံးပြုခွင့်ပေးထားလျှင်၊ %@ သည် Logi Options+ ကဲ့သို့သော အက်ပ်ပလီကေးရှင်းများမှ လုပ်ဆောင်ချက်များကို အသုံးမပြုပါ။."
          }
        },
        "nb-NO" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "If enabled, %@ will not modify events sent by other applications, such as Logi Options+."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Indien ingeschakeld, zal %@ instellingen die door andere applicaties worden beheerd, zoals Logi Options+, niet wijzigen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jeżeli włączone, %@ nie będzie modyfikował zdarzeń wysłanych przez inne aplikacje, takich jak Logi Options+."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se ativado, %@ não modificará eventos enviados por outros aplicativos, como Logi Options+."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se habilitado, %@ não irá modificar eventos enviados por outras aplicações, como Logi Options+."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dacă este activat, %@ nu va modifica evenimentele trimise de alte aplicații, cum ar fi Logi Options+."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если включено, %@ не будет изменять события, отправленные другими приложениями, такими как Logi Options+."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Po zapnutí %@ nebude upravovať udalosti odoslané inými aplikáciami, ako napr. Logi Options+."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ако је омогућено, %@ неће мењати догађаје послате од стране других апликација, као што је Logi Options+."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Om aktiverat kommer %@ inte att ändra händelser som skickas av andra program, som Logi Options+."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Etkinleştirilirse, %@, Logi Options+ gibi diğer uygulamalar tarafından gönderilen olayları değiştirmeyecektir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Якщо увімкнено, %@ не змінюватиме події, надіслані іншими застосунками, такими як Logi Options+."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Khi bật, %@ sẽ không sửa đổi các sự kiện được gửi bởi ứng dụng khác, chẳng hạn như Logi Options+."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果启用， %@ 将不会修改其他应用程序发送的事件，如 Logi Options+。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果啟用， %@ 將不會修改其他應用程式發送的事件，如 Logi Options+。"

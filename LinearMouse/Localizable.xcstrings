    "Press and hold a button while dragging to trigger gestures like switching desktop spaces or opening Mission Control." : {
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hou 'n knoppie vas terwyl jy sleep om gebare soos om desktop-spasies te verander of Mission Control oop te maak, te aktiveer."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اضغط مع الاستمرار على زر أثناء السحب لتشغيل إيماءات مثل التبديل بين مساحات سطح المكتب أو فتح Mission Control."
          }
        },
        "bs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pritisnite i držite dugme dok prevlačite da biste pokrenuli geste poput prebacivanja na drugi prostor na radnoj površini ili otvaranja Mission Controla."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantén premut un botó mentre arrossegares per activar gestos com canviar d'espais d'escriptori o obrir el Control de missió."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Podržte tlačítko a přetáhněte jej, abyste aktivovali gesta, jako je přepínání ploch nebo otevření Mission Control."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tryk og hold en knap nede, mens du trækker, for at udløse bevægelser som f.eks. at skifte skrivebordsrum eller åbne Mission Control."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Halten Sie eine Schaltfläche gedrückt, während Sie ziehen, um Gesten wie das Wechseln von Desktop-Spaces oder das Öffnen von Mission Control auszulösen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Πατήστε και κρατήστε πατημένο ένα κουμπί ενώ σύρετε για να ενεργοποιήσετε χειρονομίες όπως η εναλλαγή χώρων επιφάνειας εργασίας ή το άνοιγμα του Mission Control."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantén pulsado el botón y arrastra para producir gestos como cambiar espacios o abrir Mission Control."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Paina ja pidä painiketta painettuna vetäessäsi aktivoidaksesi eleitä, kuten työpöytätilojen vaihtamista tai Mission Controlin avaamista."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maintenez un bouton enfoncé tout en faisant glisser pour déclencher des gestes tels que le changement d’espace de bureau ou l’ouverture de Mission Control."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "לחץ והחזק לחצן תוך כדי גרירה כדי להפעיל מחוות כמו מעבר בין סביבות שולחן עבודה או פתיחת Mission Control."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tartsa lenyomva egy gombot, miközben húzza, hogy olyan gesztusokat aktiváljon, mint az asztali területek közötti váltás vagy a Mission Control megnyitása."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Press and hold a button while dragging to trigger gestures like switching desktop spaces or opening Mission Control."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tieni premuto un pulsante mentre trascini per attivare gesti come il passaggio tra spazi desktop o l'apertura di Mission Control."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ボタンを押したままドラッグして、デスクトップスペースの切り替えやMission Controlの起動などのジェスチャーをトリガーします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "버튼을 누른 상태에서 드래그하여 데스크탑 스페이스 전환 또는 Mission Control 열기와 같은 제스처를 트리거합니다."
          }
        },
        "my" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Press and hold a button while dragging to trigger gestures like switching desktop spaces or opening Mission Control."
          }
        },
        "nb-NO" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Press and hold a button while dragging to trigger gestures like switching desktop spaces or opening Mission Control."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Houd een knop ingedrukt terwijl u sleept om gebaren te activeren, zoals het wisselen van bureaubladruimtes of het openen van Mission Control."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Naciśnij i przytrzymaj przycisk podczas przeciągania, aby aktywować gesty, takie jak przełączanie przestrzeni pulpitu lub otwieranie Mission Control."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantenha um botão pressionado enquanto arrasta para acionar gestos como alternar entre espaços de desktop ou abrir o Mission Control."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pressione e segure um botão enquanto arrasta para acionar gestos como alternar espaços da área de trabalho ou abrir o Mission Control."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ține apăsat un buton în timp ce tragi pentru a declanșa gesturi precum comutarea spațiilor de lucru sau deschiderea Mission Control."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нажмите и удерживайте кнопку во время перетаскивания, чтобы активировать жесты, такие как переключение рабочих столов или открытие Mission Control."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Podržte tlačidlo a zároveň potiahnite, čím spustíte gestá, ako je prepínanie plôch alebo otvorenie Mission Control."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Притисните и задржите дугме док вучете да бисте активирали покрете попут пребацивања радних простора или отварања Mission Control."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Håll ner en knapp medan du drar för att aktivera gester som att byta skrivbordsutrymmen eller öppna Mission Control."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Masaüstü alanları arasında geçiş yapma veya Mission Control'ü açma gibi hareketleri tetiklemek için sürüklerken bir düğmeyi basılı tutun."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Натисніть і утримуйте кнопку під час перетягування, щоб активувати жести, як-от перемикання між просторами робочого столу або відкриття Mission Control."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nhấn và giữ một nút trong khi kéo để kích hoạt các cử chỉ như chuyển đổi không gian máy tính hoặc mở Mission Control."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "按住按钮并拖动以触发切换桌面空间或打开调度中心等手势。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "按住按鈕並拖移，以觸發切換桌面空間或開啟「預覽」等手勢。"
          }
        },
        "zh-Hant-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "按住按鈕並拖曳，以觸發切換桌面空間或開啟「動態桌面」等手勢。"
          }
        }
      }
    },

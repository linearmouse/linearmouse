    "Enabling this option will log all input events, which may increase CPU usage while using %@, but can be useful for troubleshooting." : {
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deur hierdie opsie te aktiveer, sal alle invoergebeurtenisse aangeteken word, wat die SVE-gebruik kan verhoog terwyl %@ gebruik word, maar nuttig kan wees vir probleemoplossing."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيؤدي تمكين هذا الخيار إلى تسجيل جميع أحداث الإدخال، مما قد يزيد من استخدام وحدة المعالجة المركزية أثناء استخدام %@، ولكنه قد يكون مفيدًا لاستكشاف الأخطاء وإصلاحها."
          }
        },
        "bs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Omogućavanje ove opcije će logirati sve ulazne događaje, što može povećati korištenje procesora prilikom korištenja %@, ali može biti korisno za rješavanje problema."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Habilitar aquesta opció registrarà tots els esdeveniments d'entrada, cosa que pot augmentar l'ús de la CPU mentre s'utilitza %@, però pot ser útil per a la resolució de problemes."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Povolení volby bude protokolovat všechny vstupní události, což může zatížit CPU při používání %@, ale může být užitečné při řešení potíží."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktivering af denne indstilling vil logge alle input-begivenheder, hvilket kan øge CPU-forbruget mens du bruger %@, men kan være nyttigt til fejlfinding."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn diese Option aktiviert ist, werden alle Eingabeereignisse protokolliert, was die CPU-Auslastung während der Verwendung von %@ erhöhen, jedoch bei der Fehlersuche nützlich sein kann."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Η ενεργοποίηση αυτής της επιλογής θα καταγράφει όλα τα συμβάντα εισόδου, κάτι που μπορεί να αυξήσει τη χρήση της CPU κατά τη χρήση του %@, αλλά μπορεί να είναι χρήσιμη για την αντιμετώπιση προβλημάτων."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Habilitar esta opción registrará todos los eventos de entrada, lo que puede aumentar el uso de CPU al usar %@, pero puede ser útil para solucionar problemas."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tämän asetuksen käyttöönotto kirjaa kaikki syötetapahtumat, mikä voi lisätä suorittimen käyttöä käytettäessä %@, mutta voi olla hyödyllistä vianmäärityksessä."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Activer cette option va enregistrer tous les événements d'entrée, ce qui peut augmenter l'utilisation du processeur en utilisant %@, mais peut être utile pour le dépannage."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "הפעלת אפשרות זו תעשה לוג לכל אירוע קלט, מה שיכול להגביר את השימוש ב-CPU כאשר משתמשים ב-%@, אבל יכול לעזור לפתרון בעיות."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ennek az opciónak az engedélyezése naplózza az összes beviteli eseményt, ami növelheti a CPU használatát a(z) %@ használata közben, de hasznos lehet a hibaelhárításhoz."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Enabling this option will log all input events, which may increase CPU usage while using %@, but can be useful for troubleshooting."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abilitando questa opzione verranno registrati tutti gli eventi di input. Questo potrebbe incrementare l'uso della CPU quando %@ è in esecuzione, ma può essere utile per la risoluzione dei problemi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このオプションを有効にすると、すべての入力イベントが記録されるため、 %@の使用中に CPU 使用率が増加する可能性がありますが、トラブルシューティングに役立ちます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 옵션을 활성화하면 모든 입력 이벤트가 기록되며, 이는 %@를 사용하는 동안 CPU 사용량을 증가시킬 수 있지만 문제 해결에 유용할 수 있습니다."
          }
        },
        "my" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ဤရွေးချယ်မှုကို ဖွင့်ခြင်းဖြင့် အားလုံးသော အသုံးပြုမှုဖြစ်ရပ်များကို မှတ်တမ်းတင်ပါမည်။ ၄င်းသည် %@ ကို အသုံးပြုနေစဉ် CPU အသုံးပြုမှုကို တိုးမြှင့်နိုင်ပါသည်၊ သို့သော် ပြဿနာများကို ဖြေရှင်းရန် အသုံးဝင်နိုင်ပါသည်။."
          }
        },
        "nb-NO" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Enabling this option will log all input events, which may increase CPU usage while using %@, but can be useful for troubleshooting."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Het inschakelen van deze optie zal alle invoer-gebeurtenissen loggen, wat het CPU-gebruik kan verhogen terwijl je %@ gebruikt, maar kan nuttig zijn voor het oplossen van problemen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Włączenie tej opcji spowoduje rejestrowanie wszystkich zdarzeń wejściowych, co może zwiększyć użycie procesora podczas używania %@, ale może być użyteczne przy rozwiązywaniu problemów."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ativar esta opção registrará todos os eventos de entrada, o que pode aumentar o uso da CPU ao usar %@, mas pode ser útil para solução de problemas."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Habilitar esta opção irá registrar todos os eventos de entrada, o que pode aumnetar o uso de CPU enquanto utiliza %@ mas pode ser útil para solução de problemas."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Activarea acestei opțiuni va înregistra toate evenimentele de intrare, ceea ce poate crește utilizarea procesorului în timp ce utilizați %@, dar poate fi utilă pentru depanare."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Включение этой опции влияет на запись в журнал всех входящих событий, что может увеличить нагрузку на ЦП при использовании %@, но будет полезно для поиска неполадок."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zapnutím tejto možnosti sa zaznamenajú všetky vstupné udalosti, čo môže zvýšiť využitie procesora pri používaní %@, ale môže to byť užitočné pri riešení problémov."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Омогућавање ове опције ће евидентирати све улазне догађаје, што може повећати коришћење ЦПУ-а током коришћења %@, али може бити корисно за решавање проблема."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Att aktivera detta alternativ loggar alla inmatningshändelser, vilket kan öka CPU-användningen när du använder %@, men kan vara användbart för felsökning."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu seçeneğin etkinleştirilmesi, %@ kullanılırken CPU kullanımını arttırabilir, ancak sorun giderme için faydalı olabilecek tüm giriş olaylarını loglara kaydedecektir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Увімкнення цього пункту призведе до реєстрації усіх подій введення, що може збільшити використання ЦП під час використання %@, але може бути корисним для пошуку та усунення несправностей."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bật tùy chọn này sẽ ghi nhật ký tất cả các sự kiện đầu vào, điều này có thể làm tăng mức sử dụng CPU khi sử dụng %@, nhưng có thể hữu ích cho việc khắc phục sự cố."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "启用此选项将记录所有输入事件，这可能增加使用 %@ 时的 CPU 使用率，但有助于排除故障。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "啟用此選項將記錄所有輸入事件，這可能增加使用 %@ 時的 CPU 使用率，但有助於排除故障。"
          }
        },
        "zh-Hant-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "啟用此選項將記錄所有輸入事件，這可能增加使用 %@ 時的 CPU 使用率，但有助於排除故障。"
          }
        }
      }
    },

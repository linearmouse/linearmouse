    "Due to system limitations, this device may not support adjusting Pointer Speed on newer versions of macOS." : {
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As gevolg van stelselbeperkings, ondersteun hierdie toestel dalk nie die aanpassing van wysersnelheid op nuwer weergawes van macOS nie."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "بسبب قيود النظام، قد لا يدعم هذا الجهاز ضبط سرعة المؤشر في الإصدارات الأحدث من macOS."
          }
        },
        "bs" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Due to system limitations, this device may not support adjusting Pointer Speed on newer versions of macOS."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A causa de les limitacions del sistema, aquest dispositiu pot no suportar l'ajust de la velocitat del punter en versions més recents de macOS."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kvůli systémovým omezením nemusí toto zařízení podporovat úpravu rychlosti ukazatele v novějších verzích macOS."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "På grund af systembegrænsninger understøtter denne enhed muligvis ikke justering af markørhastighed på nyere versioner af macOS."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aufgrund von Systembeschränkungen unterstützt dieses Gerät möglicherweise nicht die Anpassung der Zeigergeschwindigkeit in neueren Versionen von macOS."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Λόγω περιορισμών συστήματος, αυτή η συσκευή ενδέχεται να μην υποστηρίζει την προσαρμογή της ταχύτητας του δείκτη σε νεότερες εκδόσεις του macOS."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Debido a limitaciones del sistema, es posible que este dispositivo no admita el ajuste de la velocidad del puntero en las versiones más recientes de macOS."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Järjestelmän rajoitusten vuoksi tämä laite ei ehkä tue osoittimen nopeuden säätämistä macOS:n uudempien versioiden kanssa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En raison de limitations système, ce périphérique pourrait ne pas prendre en charge le réglage de la vitesse du pointeur sur les versions plus récentes de macOS."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "עקב מגבלות מערכת, ייתכן שמכשיר זה אינו תומך בהתאמת מהירות המצביע בגרסאות חדשות יותר של macOS."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rendszerkorlátozások miatt ez az eszköz nem támogatja a Mutató sebességének beállítását a macOS újabb verzióin."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Due to system limitations, this device may not support adjusting Pointer Speed on newer versions of macOS."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A causa di limitazioni di sistema, questo dispositivo potrebbe non supportare la regolazione della velocità del puntatore nelle versioni più recenti di macOS."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "システム上の制限により、このデバイスはmacOSの新しいバージョンでポインター速度の調整をサポートしていない場合があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "시스템 제한으로 인해 이 기기는 최신 버전의 macOS에서 포인터 속도 조정을 지원하지 않을 수 있습니다."
          }
        },
        "my" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "စနစ်၏ ကန့်သတ်ချက်များကြောင့်၊ ဤစက်ပစ္စည်းသည် macOS ၏ နောက်ဆုံးဗားရှင်းများတွင် Pointer Speed ကို ချိန်ညှိခြင်းကို မထောက်ပံ့နိုင်ပါ။"
          }
        },
        "nb-NO" : {

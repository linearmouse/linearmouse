    "When using plain middle click, keep browser-style middle-click behavior on pressable elements instead of entering autoscroll." : {
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wanneer jy gewone middelkliek gebruik, behou blaaier-styl middelkliek-gedrag op drukbare elemente in plaas daarvan om outo-rol te betree."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "عند استخدام النقر الأوسط العادي، احتفظ بسلوك النقر الأوسط بأسلوب المتصفح على العناصر القابلة للضغط بدلاً من الدخول في التمرير التلقائي."
          }
        },
        "bs" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "When using plain middle click, keep browser-style middle-click behavior on pressable elements instead of entering autoscroll."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quan utilitzeu el clic central simple, manteniu el comportament de clic central a l'estil del navegador en elements clicables en lloc d'entrar en el desplaçament automàtic."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Při použití běžného prostředního kliknutí zachovejte chování prostředního kliknutí ve stylu prohlížeče na prvcích, na které lze kliknout, místo automatického posouvání."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Når du bruger et almindeligt mellemklik, skal du bevare browser-lignende mellemklik-adfærd på klikbare elementer i stedet for at gå ind i autoscroll."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verwende bei einfachem Mittelklick das browserähnliche Verhalten für klickbare Elemente anstelle des automatischen Scrollens."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Όταν χρησιμοποιείτε απλό μεσαίο κλικ, διατηρήστε τη συμπεριφορά μεσαίου κλικ τύπου προγράμματος περιήγησης σε στοιχεία που μπορούν να πατηθούν αντί να εισέλθετε σε αυτόματη κύλιση."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Al usar el clic central simple, mantén el comportamiento de clic central estilo navegador en elementos interactivos en lugar de entrar en desplazamiento automático."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kun käytät tavallista keskinäppäintä, säilytä selaimeen tyypillinen keskinäppäimen toiminta painettavissa olevissa elementeissä sen sijaan, että siirtyisit automaattiseen vieritykseen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lors de l'utilisation du clic central simple, conservez le comportement de clic central de type navigateur sur les éléments cliquables au lieu d'activer le défilement automatique."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "בעת שימוש בלחיצה אמצעית רגילה, שמור על התנהגות לחיצה אמצעית בסגנון דפדפן באלמנטים הניתנים ללחיצה במקום להיכנס לגלילה אוטומטית."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Egyszerű középső kattintás használatakor a kattintható elemek böngészőstílusú középső kattintási viselkedését tartja meg az automatikus görgetés helyett."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "When using plain middle click, keep browser-style middle-click behavior on pressable elements instead of entering autoscroll."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando si utilizza il clic centrale normale, mantieni il comportamento del clic centrale in stile browser sugli elementi cliccabili invece di entrare nello scorrimento automatico."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "通常のミドルクリックを使用する場合、自動スクロールに入る代わりに、クリック可能な要素でブラウザスタイルのミドルクリック動作を維持します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "일반 중간 클릭을 사용할 때 자동 스크롤로 들어가는 대신 클릭 가능한 요소에서 브라우저 스타일 중간 클릭 동작을 유지합니다."
          }
        },
        "my" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "အလယ်ကလစ်ကို အသုံးပြုသည့်အခါ၊ အလိုအလျောက် scroll လုပ်ခြင်းအစား click လုပ်နိုင်သော အရာများပေါ်တွင် browser-style အလယ်ကလစ် အပြုအမူကို ထိန်းသိမ်းပါ။"
          }
        },
        "nb-NO" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "When using plain middle click, keep browser-style middle-click behavior on pressable elements instead of entering autoscroll."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Houd bij gebruik van een gewone middenklik het gedrag van de middenklik in browserstijl op klikbare elementen in plaats van automatisch scrollen te starten."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Podczas używania zwykłego środkowego kliknięcia zachowaj przeglądarkowe zachowanie środkowego kliknięcia na elementach klikalnych zamiast wchodzić w tryb przewijania automatycznego."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ao usar clique do meio simples, mantenha o comportamento de clique do meio no estilo do navegador em elementos clicáveis em vez de entrar na rolagem automática."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ao usar o clique do meio simples, mantenha o comportamento de clique do meio no estilo do navegador em elementos clicáveis em vez de entrar na rolagem automática."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Când utilizați clic de mijloc simplu, păstrați comportamentul de clic de mijloc în stil browser pe elementele care pot fi apăsate, în loc să intrați în derulare automată."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "При использовании обычного среднего клика сохраняйте поведение среднего клика в стиле браузера на интерактивных элементах вместо перехода в режим автопрокрутки."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pri použití bežného stredného kliknutia zachovajte správanie stredného kliknutia v štýle prehliadača na prvkoch, na ktoré sa dá kliknúť, namiesto vstupu do automatického posúvania."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Када користите обичан средњи клик, задржите понашање средњег клика у стилу прегледача на елементима на које се може кликнути уместо уласка у аутоматско скроловање."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "När du använder vanligt mittenklick, behåll webbläsarstilens mittenklicksbeteende på klickbara element istället för att aktivera autoskrollning."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Düz orta tıklama kullanırken, otomatik kaydırmaya girmek yerine tıklanabilir öğelerde tarayıcı tarzı orta tıklama davranışını koruyun."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Під час використання звичайного середнього клацання зберігайте поведінку середнього клацання в стилі браузера на натискних елементах замість автоматичного прокручування."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Khi sử dụng nhấp chuột giữa thông thường, giữ nguyên hành vi nhấp chuột giữa kiểu trình duyệt trên các phần tử có thể nhấp thay vì vào chế độ tự động cuộn."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用纯中间键单击时，在可按元素上保留浏览器风格的中间键单击行为，而不是进入自动滚动。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用純中間點擊時，在可按元素上保留瀏覽器風格的中間點擊行為，而非進入自動捲動。"
          }
        },
        "zh-Hant-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用純中間點擊時，請在可按元素上保留瀏覽器風格的中間點擊行為，而非進入自動捲動。"
          }
        }
      }
    },
    "You may also press ⌃⇧⌘Z to revert to system defaults." : {
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jy kan ook ⌃⇧⌘Z druk om na stelselverstekings terug te keer."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يمكنك أيضًا الضغط على ⌃⇧⌘Z للعودة إلى إعدادات النظام الافتراضية."
          }
        },
        "bs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Možete pritisnuti ⌃⇧⌘Z da biste se vratili na tvorničke postavke."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "També podeu prémer ⌃⇧⌘Z per tornar als valors predeterminats del sistema."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pro obnovení výchozího nastavení systému můžete také použít klávesovou zkratku ⌃⇧⌘Z"
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du kan også trykke på ⌃⇧⌘Z for at vende tilbage til systemets standardindstillinger."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Durch Drücken des Kürzels ⌃⇧⌘Z kann ebenfalls zu den Systemstandards zurückgekehrt werden."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Μπορείτε επίσης να πιέσετε ⌃⇧⌘Z για να επανέλθετε στις προεπιλογές του συστήματος."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "También puedes pulsar ⌃⇧⌘Z para restablecer valores por defecto."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Voit myös palauttaa järjestelmän oletusasetukset painamalla ⌃⇧⌘Z."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous pouvez aussi appuyer sur ⌃⇧⌘Z pour réinitialiser aux paramètres par défauts du système."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ניתן גם ללחוץ ⌃⇧⌘Z כדי לחזור לברירת המחדל של המערכת."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nyomja meg a ⌃⇧⌘Z billentyűkombinációt is a rendszer alapértékeihez való visszaállításhoz."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "You may also press ⌃⇧⌘Z to revert to system defaults."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Puoi anche premere ⌃⇧⌘Z per ripristinare le impostazioni predefinite."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "<unk> ⌘Z を押してデフォルトに戻れます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌃⇧⌘Z를 눌러 시스템 기본값으로 되돌릴 수도 있습니다."
          }
        },
        "my" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "စနစ်မူလ setting သို့ ပြန်သွားရန် ⌃⇧⌘Z ကိုလည်း နှိပ်နိုင်ပါသည်။."
          }
        },
        "nb-NO" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "You may also press ⌃⇧⌘Z to revert to system defaults."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je kunt ook ⌃⇧⌘Z indrukken om terug te keren naar de standaard systeeminstellingen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Możesz także nacisnąć ⌃⇧⌘Z, aby przywrócić ustawienia systemowe."
          }
        },
        "pt" : {

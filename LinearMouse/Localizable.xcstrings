    "Some gestures, such as swiping back and forward, may stop working." : {
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sommige gebare, soos om terug en vorentoe te vee, sal dalk nie werk nie."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قد تتوقف بعض الإيماءات، مثل السحب للخلف وللأمام، عن العمل."
          }
        },
        "bs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Neki pokreti, poput prevlačenja naprijed i nazad, mogu prestati funkcionisati."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alguns gestos, com ara lliscar endavant i enrere, poden deixar de funcionar."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Po aktivaci této volby mohou některá gesta, např. zpět a dopředu, přestat fungovat"
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nogle bevægelser, såsom at stryge tilbage og fremad, kan stoppe med at virke."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manche Gesten, beispielsweise Vor- und Zurück-Wischen, könnten nicht korrekt funktionieren."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Μερικές χειρονομίες, όπως το σύρσιμο πίσω και εμπρός, μπορεί να σταματήσουν να λειτουργούν."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Algunos gestos, como el deslizamiento hacia atrás y hacia delante, pueden dejar de funcionar."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jotkin eleet, kuten edestakaisin pyyhkäisy, eivät välttämättä toimi."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Certains gestes, comme le balayage avant et arrière, peuvent cesser de fonctionner."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "מחוות מסוימות, דוגמת החלקה קדימה ואחורה, עלולים להפסיק לעבוד."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Egyes gesztusok, például az előre és hátra csúsztatás, leállhatnak."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Some gestures, such as swiping back and forward, may stop working."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alcuni gesti, come scorrere avanti e indietro, potrebbero smettere di funzionare."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "前後スワイプ等、一部のジェスチャーが動作しなくなる可能性があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "앞뒤로 스와이프하는 것과 같은 일부 제스처가 작동하지 않을 수 있습니다."
          }
        },
        "my" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Swiping back and forward ကဲ့သို့ gestures အချို့သည် အလုပ်မလုပ်တော့နိုင်ပါ။."
          }
        },
        "nb-NO" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Some gestures, such as swiping back and forward, may stop working."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sommige gebaren, zoals heen en weer vegen, kunnen misschien niet meer werken."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niektóre gesty, takie jak przesuwanie wstecz i do przodu, mogą przestać działać."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alguns gestos, como deslizar para trás e para a frente, podem deixar de funcionar."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alguns gestos, como deslizar para a frente e para trás, podem parar de funcionar."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unele gesturi, cum ar fi glisarea înapoi și înainte, pot înceta să funcționeze."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Некоторые жесты, такие как смахивание «назад» и «вперед», могут перестать работать."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niektoré gestá, napríklad potiahnutie prstom dozadu a dopredu, môžu prestať fungovať."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Неки гестови, као што су превлачење уназад и унапред, можда више неће функционисати."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vissa gester, som att svepa fram och tillbaka, kan sluta arbeta."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "İleri ve geri kaydırma gibi bazı hareketler çalışmayı durdurabilir."
          }
        },
        "uk" : {

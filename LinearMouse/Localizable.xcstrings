    "Convert the back and forward side buttons to swiping gestures to allow universal back and forward functionality." : {
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Skakel die agterste en voorste syknoppies om na veebewegings om universele agter- en vooruit-funksionaliteit toe te laat."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تحويل الأزرار الجانبية للخلف وللأمام إلى إيماءات سحب للسماح بوظيفة عالمية للخلف وللأمام."
          }
        },
        "bs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pretvorite bočne tipke za kretanje naprijed i nazad u geste prevlačenja kako biste omogućili univerzalnu funkcionalnost za kretanje naprijed i nazad."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Converteix els botons laterals d'avanç i retrocés en gestos de lliscar per permetre una funcionalitat universal d'avanç i retrocés."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Převádí stisk bočních tlačítek myši pro pohyb zpět a dopředu na gesta přejetí prstem (swipe) a tím umožňuje využití tlačítek pro navigaci"
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Konverter tilbage og frem sideknapperne til strygebevægelser for at tillade universel tilbage og frem funktionalitet."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Konvertiert die Vor- und Zurück-Seitentasten in die jeweiligen Wischgesten, um eine universelle Vor- und Zurück-Funktion zu ermöglichen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Μετατρέψτε τα πίσω και προς τα εμπρός πλευρικά κουμπιά σε χειρονομίες για την καθολική ενεργοποίηση της λειτουργίας πίσω και εμπρός."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Convierte los botones laterales atrás y adelante en gestos de deslizamiento para permitir una funcionalidad universal hacia atrás y hacia delante."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Muunna sivun edestakaisin-painikkeet pyyhkäisytoiminnoiksi, jotta voit käyttää yleistä edestakaisin-toimintoa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Convertir les boutons latéraux arrière et avant en swipant pour permettre la fonctionnalité universelle de retour et d'avant."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "המרת כפתורי הצד האחורי והקדמי לתנועת החלקה כדי לאפשר פונקציות אחור וקדימה גלובליות."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alakítsa át a bal és jobb oldali gombokat ellopási gesztusokká az univerzális előre és hátra funkció engedélyezéséhez."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Convert the back and forward side buttons to swiping gestures to allow universal back and forward functionality."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Converti i pulsanti laterali avanti e indietro in gesti di scorrimento per consentire funzionalità di avanti e indietro universali."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "戻る・進むボタンをスワイプジェスチャーに変換し、システム全般における戻る・進む機能を行えるようにします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
